{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/cron.js": {
      "maxDuration": 60
    },
    "api/broadcast.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/cron", "dest": "/api/cron.js" },
    { "src": "/api/broadcast", "dest": "/api/broadcast.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 9 * * *"
    }
  ]
}
